<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingLeft="32dp"
    android:paddingRight="32dp"
    android:paddingTop="64dp"
    android:paddingBottom="32dp"
    android:background="#1A1A1A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Claude Pulse"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Paste your access token or refresh token"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginBottom="32dp" />

    <!-- Error banner - shown when token is expired/invalid -->
    <LinearLayout
        android:id="@+id/error_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#2A1A1A"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\u26a0 Token Expired"
            android:textColor="#F44336"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log into Claude Code to refresh your credentials, then run this command to get your new token:"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/mac_command"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="macOS:\nsecurity find-generic-password -s &apos;Claude Code-credentials&apos; -w | python3 -c &quot;\nimport sys, json\ncreds = json.load(sys.stdin)\nprint(creds.get(&apos;claudeAiOauth&apos;, {}).get(&apos;refreshToken&apos;, &apos;NOT FOUND&apos;))\n&quot;"
            android:textColor="#6ee7b7"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:textIsSelectable="true"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/linux_command"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Linux:\npython3 -c &quot;\nimport json\nwith open(&apos;$HOME/.claude/.credentials.json&apos;) as f:\n    creds = json.load(f)\nprint(creds.get(&apos;claudeAiOauth&apos;, {}).get(&apos;refreshToken&apos;, &apos;NOT FOUND&apos;))\n&quot;"
            android:textColor="#6ee7b7"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:textIsSelectable="true"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paste the new token below."
            android:textColor="#AAAAAA"
            android:textSize="13sp" />
    </LinearLayout>

    <EditText
        android:id="@+id/token_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dp"
        android:gravity="top|start"
        android:hint="Token..."
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:background="#2A2A2A"
        android:padding="16dp"
        android:inputType="textMultiLine"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/connect_button"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Connect"
        android:textColor="#1A1A1A"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#6ee7b7"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>
